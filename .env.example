# Required — get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Required — Instagram account credentials
# Use a secondary/burner Instagram account, NOT your personal one
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Optional — where to store the session file (default: /tmp/ig_session.json)
SESSION_FILE=/tmp/ig_session.json

# Health check port (default 8000)
PORT=8000
